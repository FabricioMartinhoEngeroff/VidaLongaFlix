{
  "title": "JVM & Backend — VidaLongaFlix",
  "uid": "jvm-backend-vlf",
  "description": "Memória JVM, threads, CPU, conexões ao banco e endpoints mais lentos",
  "tags": ["vidalongaflix", "jvm", "backend"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Memória JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Heap Memory — Usado vs Máximo",
      "description": "Se 'usado' se aproximar de 'máximo', o GC vai pausar a JVM (stop-the-world).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Heap máximo" },
            "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "Heap usado",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "Heap máximo",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_committed_bytes{area=\"heap\"})",
          "legendFormat": "Heap committed",
          "refId": "C"
        }
      ]
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Non-Heap Memory (Metaspace + Code Cache)",
      "description": "Cresce com o número de classes carregadas. Vazamento indica classloader leak.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(id) (jvm_memory_used_bytes{area=\"nonheap\"})",
          "legendFormat": "{{ id }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "row",
      "title": "CPU & Threads",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage — Processo vs Sistema",
      "description": "process_cpu_usage = só a JVM. system_cpu_usage = CPU total da máquina.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage",
          "legendFormat": "JVM (processo)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "system_cpu_usage",
          "legendFormat": "Sistema (total)",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Threads JVM",
      "description": "live = threads ativas. daemon = threads em background. peak = máximo histórico.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_daemon_threads",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_peak_threads",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ]
    },

    {
      "id": 7,
      "type": "row",
      "title": "Banco de Dados — HikariCP Connection Pool",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Conexões ao Banco (HikariCP)",
      "description": "Se 'active' ficar igual a 'max', novas requisições ficam esperando conexão → lentidão.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active",
          "legendFormat": "Ativas",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle",
          "legendFormat": "Ociosas",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_max",
          "legendFormat": "Máximo",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending",
          "legendFormat": "Aguardando",
          "refId": "D"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Tempo de Aquisição de Conexão (ms)",
      "description": "Tempo que a requisição espera até conseguir uma conexão do pool. > 100ms indica pool cheio.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(hikaricp_connections_acquire_seconds_sum[5m]) / rate(hikaricp_connections_acquire_seconds_count[5m]) * 1000",
          "legendFormat": "Tempo médio de aquisição",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "type": "row",
      "title": "HTTP — Endpoints por Latência",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Latência Média por Endpoint",
      "description": "Identifica os endpoints mais lentos. Ordene pela legenda para ver os piores.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "last"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(http_route, http_request_method) (rate(http_server_request_duration_seconds_sum[5m])) / sum by(http_route, http_request_method) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{ http_request_method }} {{ http_route }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "type": "row",
      "title": "Garbage Collector",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "GC Pause Time (ms/s)",
      "description": "Tempo que a JVM para tudo para coletar lixo. Picos altos causam lentidão visível ao usuário.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(action) (rate(jvm_gc_pause_seconds_sum[5m])) * 1000",
          "legendFormat": "GC {{ action }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 14,
      "type": "timeseries",
      "title": "Classes Carregadas (JVM)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_classes_loaded_classes",
          "legendFormat": "Classes carregadas",
          "refId": "A"
        }
      ]
    }

  ]
}
