{
  "title": "Golden Signals — VidaLongaFlix",
  "uid": "golden-signals-vlf",
  "description": "Os 4 sinais de ouro do Google SRE: Latência, Tráfego, Erros e Saturação",
  "tags": ["vidalongaflix", "sre", "golden-signals"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Latência — Quanto tempo a API demora para responder",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Latência P95 por Rota (95% das requisições abaixo deste valor)",
      "description": "Se subir, 5% dos usuários estão sentindo lentidão. Alerta recomendado: > 500ms",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(le, http_route) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95 {{ http_route }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Latência P99 por Rota (piores 1% das requisições)",
      "description": "Revela os outliers — picos que afetam poucos usuários mas indicam problemas reais",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by(le, http_route) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99 {{ http_route }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "row",
      "title": "Tráfego — Volume de requisições no sistema",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Taxa de Requisições (req/s)",
      "description": "Volume total de tráfego. Picos inesperados podem indicar ataque ou evento externo.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(http_route) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "{{ http_route }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Total de Requisições (última hora)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_request_duration_seconds_count[1h]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_uptime_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },

    {
      "id": 8,
      "type": "stat",
      "title": "Requisições com Erro (última hora)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[1h]))",
          "legendFormat": "Erros",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "row",
      "title": "Erros — Taxa de falhas 5xx",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Taxa de Erros 5xx (req/s)",
      "description": "Erros do servidor. Qualquer valor > 0 merece investigação imediata.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(http_route) (rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx {{ http_route }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Percentual de Erro por Rota (%)",
      "description": "Alerta recomendado: > 1% de erros por minuto em qualquer rota",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(http_route) (rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / sum by(http_route) (rate(http_server_request_duration_seconds_count[5m]))",
          "legendFormat": "% erro {{ http_route }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "type": "row",
      "title": "Saturação — Quão cheios estão os recursos",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },

    {
      "id": 13,
      "type": "gauge",
      "title": "JVM Heap Memory (%)",
      "description": "Alerta: > 80%. Se atingir 100%, OutOfMemoryError.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / sum(jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 14,
      "type": "gauge",
      "title": "CPU Usage (%)",
      "description": "Alerta: > 80% por mais de 5 minutos.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 15,
      "type": "stat",
      "title": "Threads Ativas (JVM)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Threads",
          "refId": "A"
        }
      ]
    },

    {
      "id": 16,
      "type": "timeseries",
      "title": "JVM Heap ao Longo do Tempo",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "Heap usado",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "Heap máx",
          "refId": "B"
        }
      ]
    }

  ]
}
